# BROKER API CONFIGURATION
# CRITICAL: Copy this file to .env and fill in your actual credentials
# CRITICAL: .env file is added to .gitignore and must NEVER be committed to version control

# Zerodha (Kite) API
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_USER_ID=your_zerodha_user_id_here
ZERODHA_PASSWORD=your_zerodha_password_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# Angel One API
ANGEL_API_KEY=your_angel_api_key_here
ANGEL_CLIENT_ID=your_angel_client_id_here
ANGEL_USER_ID=your_angel_user_id_here
ANGEL_PASSWORD=your_angel_password_here
ANGEL_TOTP_SECRET=your_angel_totp_secret_here

# SQL Server Database Configuration
DB_SERVER=DESKTOP-57PQCS1
DB_OPERATIONAL=FnO_Apr26
DB_HISTORICAL=Historical_Database

# Application Settings
LOCAL_STORAGE_DIR=./local_trading_data
LOG_LEVEL=INFO
DEBUG_MODE=False

